import random

class Character:
    def __init__(self, name):
        self.name = name
        self.hp = 100
        self.level = 1
        self.exp = 0
        self.inventory = []
        
    def add_item(self, item):
        self.inventory.append(item)
        print(f"{self.name} เก็บ {item} แล้ว")
        
    def show_inventory(self):
        if not self.inventory:
            print(f"{self.name} ไม่มีไอเทมในกระเป๋า")
        else:
            print(f"กระเป๋าของ {self.name}:")
            for item in self.inventory:
                print(f"- {item}")
                
                
class LuckyHero(Character):
    def __init__(self, name):
        super().__init__(name)
        self.hp = 100
        self.level = 1
        self.exp = 0
        self.inventory = []
        self.luck_bonus = 0.2
        
class StrongHero(Character):
    def __init__(self, name):
        super().__init__(name)
        self.hp = 100
        self.level = 1
        self.exp = 0
        self.inventory = []
        self.attack_bonus = 10
        
