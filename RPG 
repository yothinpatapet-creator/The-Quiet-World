shop_items = {
    1: {"name": "ดาบสั้น", "cost": {"เหล็ก": 5}},
    2: {"name": "ดาบยาว", "cost": {"ทอง": 8}},
    3: {"name": "ดาบเทพ", "cost": {"เพชร": 10}},
    4: {"name": "เกราะ", "cost": {"ทอง": 10}},
}

def trade(player):
    print("\n=== ร้านค้าชาวบ้าน ===")
    for key, item in shop_items.items():
        cost_text = ", ".join(f"{amount} {ore}" for ore, amount in item["cost"].items())
        print(f"[{key}] {item['name']} (ราคา: {cost_text}]")
    print("[0] ออกจากร้าน")
    
    try:
        choice = int(input("เลือกซื้อ: "))
    except ValueError:
        print("กรุณาพิมพ์ตัวเลขเท่านั้น")
        return
    
    if choice == 0:
        print("ออกจากร้านค้า")
        return
    if choice not in shop_items:
        print("ไม่มีสิ้นค้านี้")
        return
    
    item = shop_items[choice]
    
    for ore, amount in  item["cost"].items():
        if player.inventory.count(ore) < amount:
            print("คุณมีแร่ไม่พอ")
            return
        
    for ore, amount in item["cost"].items():
        for _ in range(amount):
            player.inventory.remove(ore)
            
    player.add_item(item["name"])
    print(f"คุณได้ {item['name']} แล้ว!")


