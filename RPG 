    global day
    print(f"\n--- คืนที่ {day} ---")
    print("คุณตัดสินใจพักผ่อน...")
    
    night_event = random.randint(1, 100)
    if night_event <= 50:
        print("กลางคืนมีเสียงสัตว์ร้ายดังขึ้น มีมอนสเตอร์โผล่ออกมา!")
        try:
            go_fight = int(input("จะออกไปฆ่ามอนสเตอร์ไหม? [1]ไป [2]ไม่ไป :"))
        except ValueError:
            go_fight = 2
            
        if go_fight == 1:
            fight_monster(player)
        else:
            print("คุณเลือกที่จะนอนหลับต่อ ปลอดภัยดี")
            
    else:
