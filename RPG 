def go_mining(player):
    
    print("คุณเข้าไปในเหมือง...")
    print("[1] ซ้าย [2] กลาง [3] ขวา") 
    try:
        direction = int(input("เลือกทาง: "))
    except ValueError:
        print("กรุณาพิมพ์ตัวเลขเท่านั้น")
        return
            
    if direction not in (1, 2, 3):
        print("ไม่มีทางนี้")
        return
    
    roll = random.randint(1,100)
            
    if hasattr(player, "luck_bonus"):
         roll += int(player.luck_bonus * 100)
                
    if roll >= 95:
        loot = "เพชร"
    elif roll >= 70:
        loot = "ทอง"
    elif roll >= 40:
        loot = "เหล็ก"
    else:
        loot = "หิน"
        
    print(f"คุณขุดพบ: {loot}!")
    player.add_item(loot)
    
weapon_damage = {
    "หมัด": 10,
    "ดาบสั้น": 20,
    "ดาบยาว": 35,
    "ดาบเทพ": 50,
}

def get_weapon_damage(player):
    best_damage = weapon_damage["หมัด"]
    for item in player.inventory:
        if item in weapon_damage:
            if weapon_damage[item] > best_damage:
                best_damage = weapon_damage[item]
    return best_damage
    
monster_list = ["สไลม์", "หมาป่า", "โกเลม", "ปีศาจถ้ำ"]

def check_level_up(player):
    exp_needed = player.level * 50
    
    while player.exp >= exp_needed:
        player.exp -= exp_needed
        player.level += 1
        player.hp += 20
        print(f"\n {player.name} เลเวลอัพ! ตอนนี้เลเวล {player.level}")
        print(f"HP เพิ่มขึ้นเป็น {player.hp}")
        exp_needed = player.level * 50

def fight_monster(player):
    monster_name = random.choice(monster_list)
    monster_hp = random.randint(30, 80)
    print(f"คุณเจอ {monster_name}! (HP:  {monster_hp})")
    
    while True:
        damage = get_weapon_damage(player)
        if hasattr(player, "attack_bonus"):
            damage += player.attack_bonus
        monster_hp -= damage
        print(f"คุณโจมตี {monster_name} แรง {damage}! เหลือ HP: {max(monster_hp, 0)}")
        if monster_hp <= 0:
            exp_gain = random.randint(10,30)
            player.exp += exp_gain
            print(f"คุณฆ่า {monster_name} สำเร็จ! ได้ {exp_gain} EXP")
            check_level_up(player)
            loot = random.choice(["เหล็ก", "ทอง", "เพชร"])
            player.add_item(loot)
            break
        
        monster_damage = random.randint(5, 15)
        player.hp -= monster_damage
        print(f"{monster_name} โจมตีกลับแรง {monster_damage}! เลือดของคุณเหลือ {player.hp}")
        
        if player.hp <= 0:
            print("คุณแพ้การต่อสู้....")
            break
boss_list = ["มังกรเพลิง", "ราชาโกเลม", "จอมมาร"]

def fight_boss(player):
    boss_name = random.choice(boss_list)
    boss_hp = random.randint(150,250)
    print(f"\nคุณเจอบอส {boss_name}! (HP: {boss_hp})")
    
    while True:
        damage = get_weapon_damage(player)
        if hasattr(player, "attack_bonus"):
            damage += player.attack_bonus
        boss_hp -= damage
        print(f"คุณโจมตี {boss_name} แรง {damage}! เหลือ HP: {max(boss_hp, 0)}")
        
        if boss_hp <= 0:
            exp_gain = random.randint(80, 150)
            player.exp += exp_gain
            print(f"คุณปราบ {boss_name} สำเร็จ!! ได้ {exp_gain} EXP")
            check_level_up(player)
            loot = random.choice(["เพชร", "เพชร", "ทอง"])
            player.add_item(loot)
            break
        
        boss_damage = random.randint(15,30)
        player.hp -= boss_damage
        print(f"{boss_name} โจมตีกลับแรง {boss_damage}! เลือดคุณเหลือ {player.hp}")
        
        if player.hp <= 0:
            print("คุณแพ้การต่อสู้กับบอส...")
            break
        
def explore(player):
    print("\nคุณออกไปสำรวจ...")
    boss_chance = min(5 + player.level * 5, 50)
    roll = random.randint(1, 100)
    
    if roll <= boss_chance:
        fight_boss(player)
    else:
        event = random.randint(1, 3)
        if event == 1:
            print("คุณพบสมุนไพรวิเศษ ฟื้นฟู HP!")
            player.hp += 20
            print(f"HP ปัจจุบัน: {player.hp}")
        elif event == 2:
            print("คุณพบมอนสเตอร์ขณะสำรวจ!")
            fight_monster(player)
        else:
            print("คุณสำรวจไปทั่วแต่ไม่พบอะไรเป็นพิเศษ")
            
    
